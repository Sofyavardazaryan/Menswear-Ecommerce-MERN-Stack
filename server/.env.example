PORT=5001
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/edgers_menswear

# Public URLs
SERVER_URL=http://localhost:5001
CLIENT_URL=http://localhost:5173

# JWT
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ArCa / Local Bank vPOS
ARCA_MERCHANT_ID=your_merchant_id
ARCA_TERMINAL_ID=your_terminal_id
ARCA_SECRET=your_arca_password
ARCA_API_URL=https://ipay.arca.am/payment

# Idram
IDRAM_ACCOUNT_ID=your_idram_account_id
IDRAM_SECRET_KEY=your_idram_secret_key
IDRAM_API_URL=https://idram.am/payment

# Telcell
TELCELL_SHOP_ID=your_telcell_shop_id
TELCELL_SECRET_KEY=your_telcell_secret_key
TELCELL_API_URL=https://telcell.am/paymentgateway/api
